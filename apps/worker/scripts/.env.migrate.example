# Copy to .env.migrate and fill in. .env.migrate is gitignored.
#
# R2 access keys: Cloudflare dashboard → R2 → "Manage R2 API Tokens"
# → create token with "Object Read & Write" on the assets bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional overrides
# R2_BUCKET=assets
# D1_DATABASE_NAME=daily_puzzles
# WEBP_QUALITY=78

# Set to true once you've confirmed converted images load correctly,
# to clean up the legacy .jpg files. Defaults to keeping them.
# DELETE_JPGS=false

# Print what would happen without uploading or running SQL.
# DRY_RUN=true
