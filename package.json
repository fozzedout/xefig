{
  "name": "xefig",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/worker",
    "apps/web",
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm --prefix apps/worker run dev",
    "deploy": "npm --prefix apps/worker run deploy",
    "deploy:beta": "npm --prefix apps/worker run deploy:beta",
    "deploy:dry": "npm --prefix apps/worker run deploy:dry",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:start": "npm --prefix apps/desktop run start",
    "desktop:setup-sdk": "npm --prefix apps/desktop run setup-sdk",
    "desktop:install-greenworks": "npm --prefix apps/desktop run install-greenworks",
    "desktop:pull-puzzles": "npm --prefix apps/desktop run pull-puzzles --",
    "desktop:test-demo": "npm --prefix apps/desktop run test:demo --"
  },
  "dependencies": {
    "@jsquash/webp": "^1.5.0",
    "jpeg-js": "^0.4.4",
    "upng-js": "^2.1.0"
  }
}
